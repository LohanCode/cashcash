<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}CASHCASH Gestionnaire{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
        <link rel="stylesheet" href="{{ asset('styles/tech.css') }}">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
            <link rel="stylesheet" href="{{ asset('css/gerant.css') }}">
        {% endblock %}
    </head>
    <body class="cc-body">
        <style>
            :root {
                --cc-blue-navy: #0f1f3a;
                --cc-black: #000000;
                --cc-grey-medium: #969eaa;
                --cc-grey-light: #f3f5f8;
                --cc-white: #ffffff;
                --cc-accent-red: #e5534b;
                --cc-radius: 6px;
                --cc-shadow-soft: 0 4px 12px rgba(15, 31, 58, 0.15);
                --cc-font-main: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            }
            
            /* ... (le reste de votre CSS actuel) ... */
        </style>

        {% if app.request.get('_route') != 'app_login' and app.request.get('_route') != 'app_admin_choix' %}
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">
                    <img src="{{ asset('images/logocashcash.png') }}" alt="Logo CASHCASH" height="30" class="d-inline-block align-text-top me-2">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        {% set current_route = app.request.get('_route') %}
                        {% set is_tech_page = current_route starts with 'tech' or current_route starts with 'intervention' %}
                        
                        {% if app.user.typeUtilisateur == 'technicien' or is_tech_page %}
                            {# Navigation Technicien #}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('tech_home') }}">
                                    <i class="fas fa-home me-1"></i> Tableau de bord
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('intervention_historique') }}">
                                    <i class="fas fa-history me-1"></i> Historique des interventions
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('intervention_recherche_client') }}">
                                    <i class="fas fa-search me-1"></i> Recherche client
                                </a>
                            </li>
                        {% else %}
                            {# Navigation Gestionnaire / Admin #}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_gerant_accueil') }}">
                                    <i class="fas fa-home me-1"></i> Tableau de bord
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_gerant_affectation') }}">
                                    <i class="fas fa-tasks me-1"></i> Affectations
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_gerant_statistiques') }}">
                                    <i class="fas fa-chart-bar me-1"></i> Statistiques
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_gerant_personnel') }}">
                                    <i class="fas fa-users me-1"></i> Personnel
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                    <div class="d-flex gap-2 align-items-center">
                        {% if app.user %}
                            <span class="text-light me-2">
                                <i class="fas fa-user me-1"></i> {{ app.user.prenom }} {{ app.user.nom }}
                            </span>
                        {% endif %}
                        {% if app.user and app.user.typeUtilisateur == 'admin' %}
                            <a href="{{ path('app_admin_choix') }}" class="btn btn-outline-light">
                                <i class="fas fa-exchange-alt me-1"></i> Changer d'interface
                            </a>
                            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">
                                <i class="fas fa-sign-out-alt me-1"></i> Se déconnecter
                            </a>
                        {% else %}
                            <a href="{{ path('app_logout') }}" class="btn btn-outline-light">
                                <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>
        {% endif %}

        <div class="container">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            
            {% block body %}{% endblock %}
        </div>
        
        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
        {% endblock %}
    </body>
</html>