{% extends 'base.html.twig' %}

{% block title %}Tableau de bord - Gestionnaire{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
{% endblock %}

{% block body %}
    <div class="dashboard-header">
        <h1>Tableau de bord Gérant</h1>
        <p>Bienvenue dans votre espace d'administration. Gérez vos affectations et consultez les statistiques en temps réel.</p>
    </div>

    <div class="dashboard-grid">
        <div class="dashboard-card">
            <i class="fas fa-tasks"></i>
            <h2>Gestion des Affectations</h2>
            <p>Gérez et suivez toutes les affectations concernant les techniciens</p>
            <a href="{{ path('app_gerant_affectation') }}" class="btn-dashboard">
                <i class="fas fa-arrow-right"></i> Accéder
            </a>
        </div>

        <div class="dashboard-card">
            <i class="fas fa-chart-bar"></i>
            <h2>Statistiques</h2>
            <p>Visualisez statistiques des techniciens</p>
            <a href="{{ path('app_gerant_statistiques') }}" class="btn-dashboard">
                <i class="fas fa-arrow-right"></i> Voir les statistiques
            </a>
        </div>

        <div class="dashboard-card">
            <i class="fas fa-users"></i>
            <h2>Gestion du Personnel</h2>
            <p>Administrez les comptes et les droits d'accès de vos collaborateurs.</p>
            <a href="{{ path('app_gerant_personnel') }}" class="btn-dashboard btn-rouge">
                <i class="fas fa-user-cog"></i> Gérer
            </a>
        </div>

        <div class="dashboard-card" id="exportsCard" style="display: none;">
            <i class="fas fa-file-export"></i>
            <h2>Exports Clients</h2>
            <p>Générez les fichiers XML et PDF de relance pour vos clients.</p>

            <div style="margin: 1rem 0;">
                <input type="text" id="clientSearch" placeholder="Numéro ou nom du client..." style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;">
                <button onclick="rechercherClient()" style="width: 100%; margin-top: 0.5rem; padding: 0.75rem; background: #3498db; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    Rechercher
                </button>
            </div>

            <div id="clientResult" style="margin: 1rem 0; padding: 1rem; background: #f5f5f5; border-radius: 4px; display: none;">
                <p><strong>Client trouvé:</strong> <span id="clientName"></span></p>
                <p><strong>Numéro:</strong> <span id="clientNum"></span></p>
                <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                    <button onclick="genererXmlClient()" class="btn-dashboard" style="flex: 1; background: #27ae60;">
                        <i class="fas fa-file-code"></i> XML
                    </button>
                    <button onclick="genererPdfClient()" class="btn-dashboard" style="flex: 1; background: #e74c3c;">
                        <i class="fas fa-file-pdf"></i> PDF
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let clientSelectionnee = null;

        // Afficher la carte "Exports" seulement si c'est le client lourd
        function detecterClientLourd() {
            // Si le serveur API local est accessible, on est sur le client lourd
            fetch('http://localhost:9999/api/client/data?numClient=test', { method: 'GET' })
                .then(() => {
                    document.getElementById('exportsCard').style.display = 'block';
                })
                .catch(() => {
                    document.getElementById('exportsCard').style.display = 'none';
                });
        }

        // Appeler au chargement
        window.addEventListener('DOMContentLoaded', detecterClientLourd);

        function rechercherClient() {
            let search = document.getElementById('clientSearch').value.trim();
            if (search === "") {
                alert("Entrez un numéro ou nom de client");
                return;
            }

            fetch(`http://localhost:9999/api/client/data?numClient=${encodeURIComponent(search)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.error) {
                        alert("❌ Client non trouvé: " + data.error);
                        document.getElementById('clientResult').style.display = 'none';
                    } else {
                        clientSelectionnee = data;
                        document.getElementById('clientName').textContent = data.raisSociale || "N/A";
                        document.getElementById('clientNum').textContent = data.numClient || "N/A";
                        document.getElementById('clientResult').style.display = 'block';
                    }
                })
                .catch(e => alert("❌ Erreur: " + e.message));
        }

        function genererXmlClient() {
            if (!clientSelectionnee) {
                alert("Sélectionnez d'abord un client");
                return;
            }

            let url = `http://localhost:9999/api/client/xml?numClient=${encodeURIComponent(clientSelectionnee.numClient)}&filename=client_${encodeURIComponent(clientSelectionnee.numClient)}`;

            fetch(url)
                .then(response => response.blob())
                .then(blob => {
                    let link = document.createElement('a');
                    link.href = window.URL.createObjectURL(blob);
                    link.download = `client_${clientSelectionnee.numClient}.xml`;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    window.URL.revokeObjectURL(link.href);
                })
                .catch(e => alert("❌ Erreur: " + e.message));
        }

        function genererPdfClient() {
            if (!clientSelectionnee) {
                alert("Sélectionnez d'abord un client");
                return;
            }

            let url = `http://localhost:9999/api/client/pdf?numClient=${encodeURIComponent(clientSelectionnee.numClient)}&filename=relance_${encodeURIComponent(clientSelectionnee.numClient)}`;

            fetch(url)
                .then(response => response.blob())
                .then(blob => {
                    let link = document.createElement('a');
                    link.href = window.URL.createObjectURL(blob);
                    link.download = `relance_${clientSelectionnee.numClient}.pdf`;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    window.URL.revokeObjectURL(link.href);
                })
                .catch(e => alert("❌ Erreur: " + e.message));
        }
    </script>
{% endblock %}
